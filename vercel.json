{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=0, no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/article/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Discordbot|Slackbot|Applebot|TelegramBot|Pinterest|Google-Structured-Data-Testing-Tool|Bingbot|DuckDuckBot).*"
        }
      ],
      "destination": "/api/og/:id"
    },
    {
      "source": "/article/:id/",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|Discordbot|Slackbot|Applebot|TelegramBot|Pinterest|Google-Structured-Data-Testing-Tool|Bingbot|DuckDuckBot).*"
        }
      ],
      "destination": "/api/og/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
